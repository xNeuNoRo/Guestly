@using System
@using Guestly.Application.Models.Emails
@model ReservationConfirmedModel

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reserva Confirmada - Guestly</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'SF Pro Display', 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f0f4f8; color: #1a202c;">
    
    <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);">
        
        <tr>
            <td align="center" style="padding: 50px 40px; background: #1e293b; background: linear-gradient(135deg, #1e293b 0%, #4f46e5 100%);">
                <table border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        <td style="background-color: rgba(255,255,255,0.1); padding: 10px 20px; border-radius: 12px;">
                            <h1 style="margin: 0; color: #ffffff; font-size: 28px; font-weight: 800; letter-spacing: -1px; font-style: italic;">GUESTLY</h1>
                        </td>
                    </tr>
                </table>
                <p style="margin: 15px 0 0; color: #e2e8f0; font-size: 18px; font-weight: 600;">¡Tu estancia está confirmada!</p>
            </td>
        </tr>

        <tr>
            <td style="padding: 0;">
                <img src="@Model.PropertyImageUrl" alt="Vista previa del alojamiento" style="width: 100%; height: 300px; object-fit: cover; display: block;">
            </td>
        </tr>

        <tr>
            <td style="padding: 40px;">
                <h2 style="margin: 0 0 10px; color: #0f172a; font-size: 24px; font-weight: 700;">¡Todo listo para tu viaje, @Model.GuestName!</h2>
                <p style="margin: 0 0 30px; line-height: 1.6; color: #64748b; font-size: 16px;">
                    Tu reserva en <strong>@Model.PropertyTitle</strong> ha sido confirmada con éxito. Prepárate para una experiencia inolvidable.
                </p>

                <table width="100%" border="0" cellpadding="0" cellspacing="0" style="background-color: #f8fafc; border-radius: 20px; border: 1px solid #e2e8f0; margin-bottom: 30px;">
                    <tr>
                        <td style="padding: 25px;">
                            <h3 style="margin: 0 0 5px; color: #1e293b; font-size: 20px; font-weight: 700;">@Model.PropertyTitle</h3>
                            <p style="margin: 0; color: #64748b; font-size: 14px;">📍 @Model.PropertyLocation</p>
                            
                            <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-top: 25px; border-top: 1px solid #e2e8f0; padding-top: 20px;">
                                <tr>
                                    <td width="50%" style="padding-bottom: 20px;">
                                        <p style="margin: 0; color: #94a3b8; font-size: 11px; text-transform: uppercase; font-weight: 700;">Llegada</p>
                                        <p style="margin: 2px 0 0; color: #1e293b; font-size: 15px; font-weight: 600;">@Model.CheckInDate.ToString("dd MMM, yyyy")</p>
                                    </td>
                                    <td width="50%" style="padding-bottom: 20px;">
                                        <p style="margin: 0; color: #94a3b8; font-size: 11px; text-transform: uppercase; font-weight: 700;">Salida</p>
                                        <p style="margin: 2px 0 0; color: #1e293b; font-size: 15px; font-weight: 600;">@Model.CheckOutDate.ToString("dd MMM, yyyy")</p>
                                    </td>
                                </tr>
                                <tr>
                                    <td width="50%">
                                        <p style="margin: 0; color: #94a3b8; font-size: 11px; text-transform: uppercase; font-weight: 700;">Anfitrión</p>
                                        <p style="margin: 2px 0 0; color: #1e293b; font-size: 15px; font-weight: 600;">@Model.HostName</p>
                                    </td>
                                    <td width="50%">
                                        <p style="margin: 0; color: #94a3b8; font-size: 11px; text-transform: uppercase; font-weight: 700;">Total</p>
                                        <p style="margin: 2px 0 0; color: #7c3aed; font-size: 20px; font-weight: 800;">@Model.TotalPrice.ToString("N2", System.Globalization.CultureInfo.InvariantCulture) USD</p>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </table>

                <table width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-bottom: 30px;">
                    <tr>
                        <td align="center" style="padding: 15px; background-color: #f1f5f9; border-radius: 12px; border: 1px dashed #cbd5e1;">
                            <p style="margin: 0; color: #64748b; font-size: 12px; font-weight: 600;">CÓDIGO DE RESERVA</p>
                            <p style="margin: 5px 0 0; color: #1e293b; font-size: 15px; font-weight: 700; font-family: monospace;">@Model.ReservationId</p>
                        </td>
                    </tr>
                </table>

                <table align="center" border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        <td align="center" style="border-radius: 14px;" bgcolor="#7c3aed">
                            <a href="https://guestly.com/my-reservations" target="_blank" style="padding: 18px 45px; display: inline-block; font-size: 16px; font-weight: 700; color: #ffffff; text-decoration: none; border-radius: 14px; letter-spacing: 0.5px;">
                                Gestionar mi estancia
                            </a>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>

        <tr>
            <td style="padding: 40px; background-color: #f8fafc; text-align: center;">
                <p style="margin: 0 0 8px; color: #94a3b8; font-size: 12px;">&copy; @System.DateTime.Now.Year Guestly Inc. • Viaja con exclusividad.</p>
                <p style="margin: 0; color: #cbd5e1; font-size: 11px;">
                    ¿Alguna duda? <a href="#" style="color: #4f46e5; text-decoration: none; font-weight: 600;">Contacta a soporte</a>.
                </p>
            </td>
        </tr>
    </table>
</body>
</html>