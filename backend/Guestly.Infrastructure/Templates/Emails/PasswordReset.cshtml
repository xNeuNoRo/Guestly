@using Guestly.Application.Models.Emails
@model PasswordResetModel

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Restablecer Contraseña - Guestly</title>
</head>
<body style="margin: 0; padding: 0; font-family: 'SF Pro Display', 'Helvetica Neue', Helvetica, Arial, sans-serif; background-color: #f0f4f8; color: #1a202c;">
    
    <table align="center" border="0" cellpadding="0" cellspacing="0" width="100%" style="max-width: 600px; margin: 40px auto; background-color: #ffffff; border-radius: 24px; overflow: hidden; box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);">
        
        <tr>
            <td align="center" style="padding: 60px 40px; background: #1e293b; background: linear-gradient(135deg, #1e293b 0%, #4f46e5 100%);">
                <table border="0" cellpadding="0" cellspacing="0">
                    <tr>
                        <td style="background-color: rgba(255,255,255,0.1); padding: 10px 20px; border-radius: 12px;">
                            <h1 style="margin: 0; color: #ffffff; font-size: 32px; font-weight: 800; letter-spacing: -1px; font-style: italic;">GUESTLY</h1>
                        </td>
                    </tr>
                </table>
                <p style="margin: 20px 0 0; color: #e2e8f0; font-size: 16px; font-weight: 400;">Recuperación de Acceso</p>
            </td>
        </tr>

        <tr>
            <td style="padding: 50px 40px;">
                <h2 style="margin: 0 0 16px; color: #0f172a; font-size: 26px; font-weight: 700; line-height: 1.2;">¿Olvidaste tu contraseña?</h2>
                <p style="margin: 0 0 25px; line-height: 1.7; color: #475569; font-size: 17px;">
                    Hola, @Model.FirstName. No te preocupes, a todos nos pasa. Haz clic en el botón de abajo para elegir una nueva contraseña y volver a planear tu próxima estancia.
                </p>

                <table align="left" border="0" cellpadding="0" cellspacing="0" style="margin-bottom: 30px;">
                    <tr>
                        <td align="center" style="border-radius: 14px;" bgcolor="#7c3aed">
                            <a href="@Model.ResetLink" target="_blank" style="padding: 18px 40px; display: inline-block; font-size: 16px; font-weight: 700; color: #ffffff; text-decoration: none; border-radius: 14px; letter-spacing: 0.5px;">
                                Restablecer mi contraseña
                            </a>
                        </td>
                    </tr>
                </table>

                <div style="clear: both; margin-top: 20px; padding: 20px; background-color: #fff7ed; border-left: 4px solid #f97316; border-radius: 8px;">
                    <p style="margin: 0; color: #9a3412; font-size: 14px; line-height: 1.5;">
                        <strong>Nota de seguridad:</strong> Este enlace expirará en <strong>@Model.ExpirationMinutes minutos</strong> por motivos de seguridad. Si no solicitaste este cambio, puedes ignorar este correo; tu contraseña actual seguirá siendo segura.
                    </p>
                </div>

                <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid #e2e8f0;">
                    <p style="margin: 0; line-height: 1.6; color: #94a3b8; font-size: 13px;">
                        ¿Problemas con el botón? Copia y pega esto en tu navegador:
                        <br>
                        <a href="@Model.ResetLink" style="color: #7c3aed; text-decoration: none; font-weight: 600; word-break: break-all;">@Model.ResetLink</a>
                    </p>
                </div>
            </td>
        </tr>

        <tr>
            <td style="padding: 40px; background-color: #f8fafc; text-align: center;">
                <p style="margin: 0 0 8px; color: #94a3b8; font-size: 12px;">&copy; @DateTime.Now.Year Guestly Inc. Distrito Nacional, RD.</p>
                <p style="margin: 0; color: #cbd5e1; font-size: 11px;">
                    Centro de Seguridad Guestly • Protegiendo tu cuenta 24/7
                </p>
            </td>
        </tr>
    </table>
</body>
</html>